---
interface Props {
  period: string;
  title: string;
  description: string;
  side: "left" | "right";
  slug: string;
}

const { period, title, description, side, slug } = Astro.props;
---

<div
  data-activity-slug={slug}
  class={`journey-card w-full max-w-[592px] rounded-[12px] md:rounded-[15px] border border-[#8E8E8E] bg-[#DADADA] p-4 md:p-6 flex flex-col gap-2 md:gap-3 ${side === "left" ? "mr-auto" : "ml-auto"}`}
>
  <span data-activity-period class="text-[#595959] text-xs md:text-sm"
    >{period}</span
  >
  <h3 data-activity-title class="text-black text-base md:text-xl font-semibold">
    {title}
  </h3>
  <p data-activity-desc class="text-black text-sm md:text-base leading-relaxed">
    {description}
  </p>
</div>
