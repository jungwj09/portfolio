---
import SectionTitle from "@/components/common/SectionTitle.astro";
import JourneyCard from "./ActivityCard.astro";
import journeys from "@/data/activities.json";
import { Plus, Minus } from "lucide-astro";
---

<section
  id="journey"
  class="relative w-full py-12 px-5 md:px-16 lg:px-32 overflow-hidden"
>
  <SectionTitle
    title="활동"
    subtitle="그동안의 제 활동을 소개할게요"
    titleKey="activity.title"
    subtitleKey="activity.subtitle"
  />

  <div class="flex gap-2 md:gap-3 mb-8 md:mb-12">
    <button
      id="btn-recent"
      class="px-3 md:px-5 py-2 md:py-2.5 rounded-lg text-xs md:text-sm font-semibold border border-white bg-transparent text-white transition-all duration-200 journey-sort-btn active-sort"
      data-i18n="activity.sort.recent"
    >
      최근 활동부터
    </button>
    <button
      id="btn-old"
      class="px-3 md:px-5 py-2 md:py-2.5 rounded-lg text-xs md:text-sm font-semibold border border-white/20 bg-transparent text-white/50 transition-all duration-200 journey-sort-btn"
      data-i18n="activity.sort.old"
    >
      예전 활동부터
    </button>
  </div>

  <div class="relative" id="journey-timeline">
    <div
      class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-white/20 -translate-x-1/2 z-0"
    >
    </div>
    <div class="md:hidden absolute left-3 top-0 bottom-0 w-px bg-white/20 z-0">
    </div>

    <div id="journey-list" class="flex flex-col gap-4 md:gap-0">
      {
        journeys.map((item, i) => {
          const side = i % 2 === 0 ? "left" : "right";
          const slug = `activity-${i}`;
          return (
            <div
              class="journey-item relative flex items-center w-full md:min-h-40"
              data-index={i}
            >
              <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-[#4086E6] border-2 border-[#4086E6] z-10 shrink-0" />
              <div class="md:hidden absolute left-3 top-6 -translate-x-1/2 w-2.5 h-2.5 rounded-full bg-[#4086E6] border-2 border-[#4086E6] z-10 shrink-0" />

              <div class="card-slot-left hidden md:flex w-[calc(50%-32px)] pr-6 justify-end">
                {side === "left" && (
                  <JourneyCard
                    period={item.period}
                    title={item.title}
                    description={item.description}
                    side="left"
                    slug={slug}
                  />
                )}
              </div>
              <div class="card-slot-right hidden md:flex w-[calc(50%-32px)] ml-auto pl-6 justify-start">
                {side === "right" && (
                  <JourneyCard
                    period={item.period}
                    title={item.title}
                    description={item.description}
                    side="right"
                    slug={slug}
                  />
                )}
              </div>
              <div class="card-slot-mobile md:hidden w-full pl-8">
                <JourneyCard
                  period={item.period}
                  title={item.title}
                  description={item.description}
                  side="right"
                  slug={slug}
                />
              </div>
            </div>
          );
        })
      }
    </div>
  </div>

  <div class="mt-8 flex justify-start">
    <button
      id="journey-toggle-btn"
      class="flex items-center gap-2 text-[#828282] text-base hover:text-white transition-colors duration-200"
    >
      <span id="icon-plus"><Plus size={16} /></span>
      <span id="icon-minus" style="display:none;"><Minus size={16} /></span>
      <span id="journey-toggle-text" data-i18n="activity.more">더 보기</span>
    </button>
  </div>
</section>

<style>
  .journey-item {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .journey-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .journey-item.hidden-item {
    display: none;
  }
  .active-sort {
    border-color: white !important;
    color: white !important;
  }
  .inactive-sort {
    border-color: rgba(255, 255, 255, 0.2) !important;
    color: rgba(255, 255, 255, 0.5) !important;
  }
</style>

<script>
  import { translations } from "@/data/i18n";
  import activities from "@/data/activities.json";

  const SHOW_COUNT = 4;
  let isExpanded = false;
  let isRecent = true;

  const list = document.getElementById("journey-list")!;
  const toggleBtn = document.getElementById("journey-toggle-btn")!;
  const toggleText = document.getElementById("journey-toggle-text")!;
  const iconPlus = document.getElementById("icon-plus")!;
  const iconMinus = document.getElementById("icon-minus")!;
  const btnRecent = document.getElementById("btn-recent")!;
  const btnOld = document.getElementById("btn-old")!;

  function getLang() {
    return (localStorage.getItem("lang") as "ko" | "en") ?? "ko";
  }

  function getItems() {
    return Array.from(list.querySelectorAll(".journey-item")) as HTMLElement[];
  }

  function updateActivityCards() {
    const lang = getLang();
    document
      .querySelectorAll<HTMLElement>("[data-activity-slug]")
      .forEach((card) => {
        const slug = card.dataset.activitySlug!;
        const idx = parseInt(slug.replace("activity-", ""), 10);
        const item = (activities as any[])[idx];
        if (!item) return;

        const periodEl = card.querySelector<HTMLElement>(
          "[data-activity-period]",
        );
        const titleEl = card.querySelector<HTMLElement>(
          "[data-activity-title]",
        );
        const descEl = card.querySelector<HTMLElement>("[data-activity-desc]");

        if (periodEl)
          periodEl.textContent = lang === "en" ? item.period_en : item.period;
        if (titleEl)
          titleEl.textContent = lang === "en" ? item.title_en : item.title;
        if (descEl)
          descEl.textContent =
            lang === "en" ? item.description_en : item.description;
      });
  }

  function reassignSides() {
    const items = getItems();
    items.forEach((item, i) => {
      const slotLeft = item.querySelector(".card-slot-left") as HTMLElement;
      const slotRight = item.querySelector(".card-slot-right") as HTMLElement;
      const card = (slotLeft.firstElementChild ||
        slotRight.firstElementChild) as HTMLElement | null;
      if (!card) return;
      if (i % 2 === 0) {
        if (!slotLeft.contains(card)) slotLeft.appendChild(card);
        card.classList.remove("ml-auto");
        card.classList.add("mr-auto");
      } else {
        if (!slotRight.contains(card)) slotRight.appendChild(card);
        card.classList.remove("mr-auto");
        card.classList.add("ml-auto");
      }
    });
  }

  function updateToggleUI() {
    const t = translations[getLang()];
    if (isExpanded) {
      iconPlus.style.display = "none";
      iconMinus.style.display = "";
      toggleText.textContent = t["activity.less"];
    } else {
      iconPlus.style.display = "";
      iconMinus.style.display = "none";
      toggleText.textContent = t["activity.more"];
    }
  }

  function applyVisibility() {
    const items = getItems();
    items.forEach((item, i) => {
      item.classList.remove("hidden-item");
      if (!isExpanded && i >= SHOW_COUNT) item.classList.add("hidden-item");
    });
    updateToggleUI();
  }

  function reverseOrder() {
    const items = getItems();
    items.reverse().forEach((item) => list.appendChild(item));
  }

  function animateItems() {
    const items = getItems();
    items.forEach((item) => item.classList.remove("visible"));
    items.forEach((item, i) =>
      setTimeout(() => item.classList.add("visible"), i * 80),
    );
  }

  toggleBtn.addEventListener("click", () => {
    isExpanded = !isExpanded;
    applyVisibility();
  });

  btnRecent.addEventListener("click", () => {
    if (isRecent) return;
    isRecent = true;
    btnRecent.classList.add("active-sort");
    btnRecent.classList.remove("inactive-sort");
    btnOld.classList.remove("active-sort");
    btnOld.classList.add("inactive-sort");
    reverseOrder();
    reassignSides();
    applyVisibility();
    animateItems();
  });

  btnOld.addEventListener("click", () => {
    if (!isRecent) return;
    isRecent = false;
    btnOld.classList.add("active-sort");
    btnOld.classList.remove("inactive-sort");
    btnRecent.classList.remove("active-sort");
    btnRecent.classList.add("inactive-sort");
    reverseOrder();
    reassignSides();
    applyVisibility();
    animateItems();
  });

  const observer = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("visible");
      }),
    { threshold: 0.1 },
  );
  getItems().forEach((item) => observer.observe(item));

  applyVisibility();
  updateActivityCards();
  window.addEventListener("langchange", () => {
    updateToggleUI();
    updateActivityCards();
  });
</script>
