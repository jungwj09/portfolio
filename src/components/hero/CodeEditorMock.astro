---

---

<div
  class="bg-[#1E1E1E] rounded-[15px] overflow-hidden shadow-2xl w-full max-w-[320px] md:max-w-105 lg:w-130 font-mono text-xs md:text-sm lg:text-base"
>
  <div class="flex items-center gap-2 px-4 py-3">
    <span class="w-3 h-3 rounded-full bg-[#FF5F5A]"></span>
    <span class="w-3 h-3 rounded-full bg-[#FFBE2E]"></span>
    <span class="w-3 h-3 rounded-full bg-[#2ACA44]"></span>
  </div>

  <div class="px-5 py-5 leading-7">
    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0">1</span>
      <span>
        <span class="text-[#569CD6]">const </span>
        <span class="text-[#4FC1FF]">devJino</span>
        <span class="text-[#D4D4D4]"> = {"{"}</span>
      </span>
    </div>

    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0">2</span>
      <span>
        <span class="text-white/0 select-none">__</span>
        <span class="text-[#9CDCFE]">mission: </span>
        <span class="text-[#CE9178]">"Positive Impact"</span>
        <span class="text-white">,</span>
      </span>
    </div>

    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0">3</span>
      <span>
        <span class="text-white/0 select-none">__</span>
        <span class="text-[#9CDCFE]">focus: </span>
        <span class="text-[#CE9178]">["People", "Society"]</span>
        <span class="text-white">,</span>
      </span>
    </div>

    <!-- 모바일/태블릿: 줄바꿈 -->
    <div class="lg:hidden">
      <div class="flex gap-4">
        <span class="text-[#858585] select-none w-4 text-right shrink-0">4</span
        >
        <span>
          <span class="text-white/0 select-none">__</span>
          <span class="text-[#9CDCFE]">poweredBy: </span>
          <span class="text-[#CE9178]">"Warmth of</span>
        </span>
      </div>
      <div class="flex gap-4">
        <span class="text-[#858585] select-none w-4 text-right shrink-0">5</span
        >
        <span>
          <span class="text-white/0 select-none">__</span>
          <span class="text-[#CE9178]">Technology"</span>
        </span>
      </div>
    </div>

    <!-- 데스크탑(lg+): 한 줄 -->
    <div class="hidden lg:flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0">4</span>
      <span>
        <span class="text-white/0 select-none">__</span>
        <span class="text-[#9CDCFE]">poweredBy: </span>
        <span class="text-[#CE9178]">"Warmth of Technology"</span>
      </span>
    </div>

    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0 lg:hidden"
        >6</span
      >
      <span
        class="text-[#858585] select-none w-4 text-right shrink-0 hidden lg:inline"
        >5</span
      >
      <span class="text-white">{"};"}</span>
    </div>

    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0 lg:hidden"
        >7</span
      >
      <span
        class="text-[#858585] select-none w-4 text-right shrink-0 hidden lg:inline"
        >6</span
      >
      <span>&nbsp;</span>
    </div>

    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right shrink-0 lg:hidden"
        >8</span
      >
      <span
        class="text-[#858585] select-none w-4 text-right shrink-0 hidden lg:inline"
        >7</span
      >
      <span class="whitespace-nowrap">
        <span class="text-[#4FC1FF]">devJino</span><span class="text-white"
          >.</span
        ><span class="text-[#DCDCAA]">build</span><span class="text-white"
          >();</span
        ><span class="cursor-blink text-white">|</span>
      </span>
    </div>
  </div>
</div>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  .cursor-blink {
    animation: blink 1s step-start infinite;
  }
</style>
