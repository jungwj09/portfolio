---
---

<div class="bg-[#1E1E1E] rounded-xl overflow-hidden shadow-2xl w-[520px] font-mono text-base">
  <div class="flex items-center gap-2 px-4 py-3">
    <span class="w-3 h-3 rounded-full bg-[#FF5F5A]"></span>
    <span class="w-3 h-3 rounded-full bg-[#FFBE2E]"></span>
    <span class="w-3 h-3 rounded-full bg-[#2ACA44]"></span>
  </div>

  <div class="px-5 py-5 leading-7">
    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right">1</span>
      <span>
        <span class="text-[#569CD6]">const </span>
        <span class="text-[#4FC1FF]">developer</span>
        <span class="text-[#D4D4D4]"> = {'{'}</span>
      </span>
    </div>

    <div class="flex gap-5">
      <span class="text-[#858585] select-none w-4 text-right">2</span>
      <span>
        <span class="text-white/0 select-none">__</span>
        <span class="text-[#9CDCFE]">mission: </span>
        <span class="text-[#CE9178]">"Positive Impact"</span>
        <span class="text-white">,</span>
      </span>
    </div>

    <div class="flex gap-5">
      <span class="text-[#858585] select-none w-4 text-right">3</span>
      <span>
        <span class="text-white/0 select-none">__</span>
        <span class="text-[#9CDCFE]">focus: </span>
        <span class="text-[#CE9178]">["People", "Society"]</span>
        <span class="text-white">,</span>
      </span>
    </div>
    
    <div class="flex gap-5">
      <span class="text-[#858585] select-none w-4 text-right">4</span>
      <span>
        <span class="text-white/0 select-none">__</span>
        <span class="text-[#9CDCFE]">poweredBy: </span>
        <span class="text-[#CE9178]">"Warmth of Technology"</span>
      </span>
    </div>
    
    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right">5</span>
      <span class="text-white">{'};'}</span>
    </div>
    
    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right">6</span>
      <span>&nbsp;</span>
    </div>
    
    <div class="flex gap-4">
      <span class="text-[#858585] select-none w-4 text-right">7</span>
      <span class="whitespace-nowrap">
        <span class="text-[#4FC1FF]">developer</span><span class="text-white">.</span><span class="text-[#DCDCAA]">build</span><span class="text-white">();</span>
      </span>
    </div>
  </div>
</div>