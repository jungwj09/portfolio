---
import { Github, Linkedin, Mail, Instagram } from 'lucide-astro';
import CodeEditorMock from './CodeEditorMock.astro';
import ScrollHintIsland from './ScrollHintIsland.astro';
import Tag from './Tag.astro';
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-32">
  <div class="flex flex-col lg:flex-row items-center justify-between w-full gap-16 -translate-y-16">

    <div class="flex flex-col">
      <p class="text-white text-4xl font-semibold">
        사람과 사회에 긍정적인 임팩트를 만드는 개발자
      </p>

      <h1 class="mt-[20px] text-[52px] font-bold text-white leading-tight">
        <span class="text-[#4086E6] border-b-2 border-[#3b82f6] pb-0.5">
          정우진
        </span>
        <span class="text-4xl font-semibold text-white">
          입니다
        </span>
      </h1>

      <div class="mt-[50px] flex gap-3 flex-wrap">
        <Tag label="Developer" />
        <Tag label="Startup Founder" />
      </div>

      <div class="mt-[50px] flex gap-5 items-center">
        <a href="https://github.com/jungwj09" target="_blank" aria-label="GitHub"
          class="text-[#767676]">
          <Github size={35} />
        </a>
        <a href="https://www.linkedin.com/in/jungwj09/" target="_blank" aria-label="LinkedIn"
          class="text-[#767676]">
          <Linkedin size={35} />
        </a>
        <a href="mailto:woox1jin@gmail.com" aria-label="Email"
          class="text-[#767676]">
          <Mail size={35} />
        </a>
        <a href="https://www.instagram.com/woox1jin_/" target="_blank" aria-label="Instagram"
          class="text-[#767676]">
          <Instagram size={35} />
        </a>
      </div>
    </div>

    <div class="flex-shrink-0">
      <CodeEditorMock />
    </div>

  </div>

  <ScrollHintIsland />
</section>