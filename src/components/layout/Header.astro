---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { Menu, X } from "lucide-astro";

const navItems = [
  { label: "자기소개", href: "/#about", i18n: "nav.about" },
  { label: "기술 스택", href: "/#tech", i18n: "nav.tech" },
  { label: "프로젝트", href: "/#projects", i18n: "nav.projects" },
  { label: "활동", href: "/#journey", i18n: "nav.activity" },
  { label: "연락처", href: "/#contact", i18n: "nav.contact" },
];
---

<!-- Desktop Header -->
<header
  class="hidden md:flex w-full sticky top-0 left-0 right-0 h-[72px] items-center justify-between px-6 z-50 bg-[#000000] border-b border-[#1A1A1A]"
>
  <a href="/" class="flex items-center">
    <img src="/logo/logo.svg" alt="JungWJ" class="h-[35px] w-auto" />
  </a>

  <nav
    class="w-full max-w-[600px] flex items-center justify-between text-base text-white/70"
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          data-i18n={item.i18n}
          class="w-full max-w-[120px] text-center py-1.5 px-2 font-medium hover:border-b-2 hover:border-white transition-all"
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="flex items-center">
    <LanguageSwitcher />
  </div>
</header>

<!-- Mobile Header -->
<header
  class="md:hidden w-full sticky top-0 left-0 right-0 h-[60px] flex items-center justify-between px-5 z-50 bg-[#000000] border-b border-[#1A1A1A]"
>
  <a href="/" class="flex items-center">
    <img src="/logo/logo.svg" alt="JungWJ" class="h-[35px] w-auto" />
  </a>

  <button id="mobile-menu-toggle" class="text-white p-2" aria-label="메뉴 열기">
    <span id="menu-icon-open"><Menu size={24} /></span>
    <span id="menu-icon-close" class="hidden"><X size={24} /></span>
  </button>
</header>

<!-- Mobile Dropdown Menu -->
<div
  id="mobile-menu"
  class="md:hidden fixed top-[60px] left-0 right-0 z-40 bg-black/95 backdrop-blur-md border-b border-[#1A1A1A] transform -translate-y-full opacity-0 pointer-events-none transition-all duration-300"
>
  <nav class="flex flex-col py-4 px-5">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          data-i18n={item.i18n}
          class="mobile-nav-link py-3 text-base text-white/70 font-medium border-b border-white/5 hover:text-white transition-colors"
        >
          {item.label}
        </a>
      ))
    }
    <div class="pt-4">
      <LanguageSwitcher />
    </div>
  </nav>
</div>

<script>
  const menuToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      mobileMenu?.classList.remove("-translate-y-full", "opacity-0", "pointer-events-none");
      mobileMenu?.classList.add("translate-y-0", "opacity-100", "pointer-events-auto");
      iconOpen?.classList.add("hidden");
      iconClose?.classList.remove("hidden");
    } else {
      mobileMenu?.classList.add("-translate-y-full", "opacity-0", "pointer-events-none");
      mobileMenu?.classList.remove("translate-y-0", "opacity-100", "pointer-events-auto");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    }
  }

  menuToggle?.addEventListener("click", toggleMenu);

  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });
</script>