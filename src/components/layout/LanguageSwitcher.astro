---
import { Globe } from "lucide-astro";
---

<button
  id="lang-switcher"
  class="flex items-center gap-[5px] text-base text-white border border-white px-[10px] py-[5px] rounded-[15px] transition-opacity hover:opacity-70"
  aria-label="Switch language"
>
  <Globe size={19} />
  <span id="lang-label">EN</span>
</button>

<script>
  import { translations, type Lang } from "@/data/i18n";

  const btn = document.getElementById("lang-switcher")!;
  const label = document.getElementById("lang-label")!;

  function getLang(): Lang {
    return (localStorage.getItem("lang") as Lang) ?? "ko";
  }

  function setLang(lang: Lang) {
    localStorage.setItem("lang", lang);
    applyLang(lang);
    // 모든 컴포넌트에 언어 변경 알림
    window.dispatchEvent(new CustomEvent("langchange", { detail: { lang } }));
  }

  function applyLang(lang: Lang) {
    const t = translations[lang];
    label.textContent = lang === "ko" ? "EN" : "KO";

    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.dataset.i18n as keyof typeof t;
      if (key && t[key] !== undefined) el.textContent = t[key];
    });

    document.querySelectorAll<HTMLElement>("[data-i18n-html]").forEach((el) => {
      const key = el.dataset.i18nHtml as keyof typeof t;
      if (key && t[key] !== undefined)
        el.innerHTML = (t[key] as string).replace(/\n/g, "<br />");
    });
  }

  applyLang(getLang());

  btn.addEventListener("click", () => {
    const next: Lang = getLang() === "ko" ? "en" : "ko";
    setLang(next);
  });
</script>
