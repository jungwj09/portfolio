---
import TechBadge from "./TechBadge.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  thumbnail: string;
  techStack: string[];
}

const { slug, title, description, thumbnail, techStack } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  data-project-slug={slug}
  class="project-card group flex flex-col rounded-xl md:rounded-[15px] overflow-hidden border border-white/10 bg-[#111111] transition-all duration-300 hover:shadow-2xl hover:shadow-black/40"
>
  <div class="relative w-full aspect-video overflow-hidden bg-[#1A1A1A]">
    <img
      src={thumbnail}
      alt={`${title} 썸네일`}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-104"
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <div
      class="absolute inset-0 hidden items-center justify-center bg-[#1A1A1A]"
    >
      <span class="text-white/20 text-sm font-medium">No Image</span>
    </div>
  </div>

  <div
    class="relative flex flex-col flex-1 p-4 md:p-5 gap-2 md:gap-3 overflow-hidden"
  >
    <!-- Hover gradient glow -->
    <div
      class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
      style="background: radial-gradient(ellipse at 0% 0%, rgba(64,134,230,0.07) 0%, transparent 65%);"
    >
    </div>
    <div class="relative flex flex-wrap gap-1 md:gap-1.5">
      {techStack.map((tech) => <TechBadge label={tech} />)}
    </div>
    <h3
      data-project-title
      class="relative text-white text-base md:text-xl font-bold leading-snug transition-colors duration-200"
    >
      {title}
    </h3>
    <p
      data-project-desc
      class="relative text-[#828282] text-xs md:text-sm leading-relaxed line-clamp-3 md:line-clamp-4"
    >
      {description}
    </p>
  </div>
</a>
