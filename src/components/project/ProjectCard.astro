---
import TechBadge from "./TechBadge.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  thumbnail: string;
  techStack: string[];
}

const { slug, title, description, thumbnail, techStack } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="project-card group flex flex-col rounded-[15px] overflow-hidden border border-white/10 bg-[#111111] hover:border-white/25 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/40"
>
  <div class="relative w-full aspect-[16/9] overflow-hidden bg-[#1A1A1A]">
    <img
      src={thumbnail}
      alt={`${title} 썸네일`}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <div
      class="absolute inset-0 hidden items-center justify-center bg-[#1A1A1A]"
    >
      <span class="text-white/20 text-sm font-medium">No Image</span>
    </div>
  </div>

  <div class="flex flex-col flex-1 p-5 gap-3">
    <div class="flex flex-wrap gap-1.5">
      {techStack.map((tech) => <TechBadge label={tech} />)}
    </div>
    <h3
      class="text-white text-xl font-bold leading-snug transition-colors duration-200"
    >
      {title}
    </h3>
    <p class="text-[#828282] text-sm leading-relaxed line-clamp-4">
      {description}
    </p>
  </div>
</a>
