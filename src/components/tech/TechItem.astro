---
interface Props {
  id: string;
  name: string;
  icon: string;
}
const { id, name, icon } = Astro.props;
---

<button
  class="tech-item flex flex-col items-center gap-1.5 md:gap-2 p-2 md:p-4 hover:border-white/25 transition-all duration-200 cursor-pointer group"
  data-tech-id={id}
  aria-label={name}
>
  <div class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center">
    <img
      src={icon}
      alt={name}
      class="w-7 h-7 md:w-9 md:h-9 object-contain group-hover:scale-110 transition-transform duration-200"
    />
  </div>
  <span
    class="text-[10px] md:text-xs text-white group-hover:text-white transition-colors duration-200 font-medium text-center leading-tight"
    >{name}</span
  >
</button>