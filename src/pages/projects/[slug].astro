---
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import TechBadge from "@/components/project/TechBadge.astro";
import projects from "@/data/projects.json";
import { ChevronLeft, Github, Calendar, Users, Link } from "lucide-astro";

export function getStaticPaths() {
  return (projects as any[]).map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props as { project: any };
---

<MainLayout title={`${project.title} | Dev Jino`}>
  <Header />

  <main class="w-full min-h-screen px-5 md:px-16 lg:px-32 py-10 md:py-16">
    <a
      href="/#projects"
      class="inline-flex items-center gap-1.5 text-[#828282] hover:text-white transition-colors mb-10 md:mb-12"
      style="font-size: 14px;"
    >
      <ChevronLeft size={16} />
      <span data-i18n="nav.projects">프로젝트</span>
    </a>

    <div
      class="flex flex-col lg:flex-row gap-8 lg:gap-14 items-start mb-14 md:mb-20"
    >
      <div
        class="w-full lg:w-130 shrink-0 rounded-xl overflow-hidden border border-white/10 bg-[#111111] aspect-video"
      >
        <img
          src={project.thumbnail}
          alt={`${project.title} 썸네일`}
          class="w-full h-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="w-full h-full hidden items-center justify-center">
          <span class="text-white/20 font-medium" style="font-size: 14px;"
            >No Image</span
          >
        </div>
      </div>

      <div class="flex flex-col justify-start flex-1 min-w-0">
        <h1
          data-i18n-project="title"
          class="text-white font-bold leading-tight mb-4"
          style="font-size: 32px;"
        >
          {project.title}
        </h1>

        <div class="flex flex-wrap gap-1.5 mb-4">
          {project.techStack.map((tech: string) => <TechBadge label={tech} />)}
        </div>

        <p
          data-i18n-project="description"
          class="text-[#C0C0C0] leading-relaxed mb-5"
          style="font-size: 16px;"
        >
          {project.description}
        </p>

        <div class="border-t border-white/10 mb-5"></div>

        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <Calendar size={16} class="text-[#828282] shrink-0" />
            <span
              class="text-[#828282]"
              style="font-size: 14px;"
              data-i18n-project="period"
            >
              {project.period}
            </span>
          </div>

          <div class="flex items-start gap-3">
            <Users size={16} class="text-[#828282] shrink-0 mt-0.75" />
            <span class="text-[#828282]" style="font-size: 16px;">
              {(project.team as string[]).join(", ")}
            </span>
          </div>

          {
            project.github && (
              <div class="flex items-center gap-3">
                <Github size={16} class="text-[#828282] shrink-0" />
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[#828282] hover:underline underline-offset-4 transition-colors break-all"
                  style="font-size: 14px;"
                >
                  {project.github.replace("https://", "")}
                </a>
              </div>
            )
          }

          {
            project.demo && (
              <div class="flex items-center gap-3">
                <Link size={16} class="text-[#828282] shrink-0" />
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[#828282] hover:underline underline-offset-4 transition-colors break-all"
                  style="font-size: 14px;"
                >
                  {project.demo.replace("https://", "")}
                </a>
              </div>
            )
          }
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-12 md:gap-16 max-w-215">
      <section>
        <h2
          class="text-white font-bold mb-4 pb-3 border-b border-white/10"
          style="font-size: 20px;"
          data-i18n="project.section.intro"
        >
          프로젝트 소개
        </h2>
        <p
          data-i18n-project="intro"
          class="text-[#C0C0C0] leading-loose whitespace-pre-line"
          style="font-size: 16px;"
        >
          {project.intro}
        </p>
      </section>

      <section>
        <h2
          class="text-white font-bold mb-5 pb-3 border-b border-white/10"
          style="font-size: 20px;"
          data-i18n="project.section.features"
        >
          주요 기능
        </h2>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-3"
          data-i18n-project-list="features"
        >
          {
            (project.features as string[]).map((f: string) => (
              <div class="feature-card flex items-start gap-3 px-4 py-3.5 rounded-xl border border-white/8 bg-white/3">
                <span class="mt-0.5 text-[#4086E6] text-lg leading-none shrink-0">
                  ✦
                </span>
                <span
                  class="text-[#C0C0C0] leading-relaxed"
                  style="font-size: 15px;"
                >
                  {f}
                </span>
              </div>
            ))
          }
        </div>
      </section>

      <section class="mb-10 md:mb-16">
        <h2
          class="text-white font-bold mb-5 pb-3 border-b border-white/10"
          style="font-size: 20px;"
          data-i18n="project.section.dev"
        >
          개발 내용
        </h2>
        <div
          class="flex flex-col gap-2.5"
          data-i18n-project-list="devContributions"
        >
          {
            (project.devContributions as string[]).map(
              (d: string, i: number) => (
                <div class="dev-card flex items-start gap-4 px-4 py-3.5 rounded-xl border border-white/8 bg-white/3">
                  <span
                    class="shrink-0 w-6 h-6 rounded-md bg-[#EAB736]/15 border border-[#EAB736]/25 flex items-center justify-center text-[#EAB736] font-bold"
                    style="font-size: 11px;"
                  >
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span
                    class="text-[#C0C0C0] leading-relaxed"
                    style="font-size: 15px;"
                  >
                    {d}
                  </span>
                </div>
              ),
            )
          }
        </div>
      </section>
    </div>
  </main>
  <Footer />
</MainLayout>

<script>
  import projects from "@/data/projects.json";
  import { translations } from "@/data/i18n";

  const slug = window.location.pathname
    .split("/projects/")[1]
    ?.replace(/\/$/, "");
  const project = (projects as any[]).find((p) => p.slug === slug);

  function getLang() {
    return localStorage.getItem("lang") ?? "ko";
  }

  function updatePage() {
    if (!project) return;
    const lang = getLang();

    const fieldMap: Record<string, string> = {
      title: lang === "en" ? project.title_en : project.title,
      description: lang === "en" ? project.description_en : project.description,
      period: lang === "en" ? project.period_en : project.period,
      intro: lang === "en" ? project.intro_en : project.intro,
    };

    document
      .querySelectorAll<HTMLElement>("[data-i18n-project]")
      .forEach((el) => {
        const key = el.dataset.i18nProject!;
        if (fieldMap[key] !== undefined) el.textContent = fieldMap[key];
      });

    const listMap: Record<string, string[]> = {
      features: lang === "en" ? project.features_en : project.features,
      devContributions:
        lang === "en" ? project.devContributions_en : project.devContributions,
    };

    document
      .querySelectorAll<HTMLElement>("[data-i18n-project-list]")
      .forEach((ul) => {
        const key = ul.dataset.i18nProjectList!;
        const items = listMap[key];
        if (!items) return;
        ul.querySelectorAll<HTMLElement>(":scope > div").forEach((card, i) => {
          const textSpan = card.querySelectorAll("span");
          const last = textSpan[textSpan.length - 1];
          if (last && items[i] !== undefined) last.textContent = items[i];
        });
      });

    const t = translations[lang as "ko" | "en"];
    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.dataset.i18n as keyof typeof t;
      if (key && t[key]) el.textContent = t[key];
    });
  }

  updatePage();
  window.addEventListener("langchange", updatePage);
</script>
